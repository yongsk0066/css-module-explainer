# What does NOT ship in the marketplace VSIX.
# Keep in sync with what `vsce package` uploads.

# Source & config
**/*.ts
**/*.tsx
**/*.map
**/*.js.map
**/*.d.ts.map
tsconfig*.json
rolldown.config.ts
vitest.config.ts
.oxlintrc.json
.oxfmtrc.json
.nvmrc
.gitignore
.env
.git/**

# Workspaces — we only ship `dist/` (rolldown output).
# The per-workspace `dist/` and `tsbuildinfo` from `tsc -b`
# are unused at runtime and must NOT be packaged.
shared/
server/
client/
!dist/**/*.js
!server/package.json

# Development tree
docs/
test/
examples/
.github/
.vscode/
.personal_docs/
.changeset/
.worktrees/
scripts/
RELEASING.md
pnpm-workspace.yaml

# Build artifacts we don't need
**/*.tsbuildinfo
coverage/
*.log
pnpm-lock.yaml
.pnpm-store/

# pnpm symlinks inside workspace packages — vsce's yazl zipper
# can't follow them. The actual runtime code is in dist/*.
node_modules/
**/node_modules/

# Scaffolding we don't ship (README, CHANGELOG, LICENSE DO ship)
.oxfmtrc.json
.editorconfig
