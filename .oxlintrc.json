{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true,
    "es2022": true
  },
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": "error",
    "no-undef": "error"
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "coverage/**", "**/*.d.ts"]
}
