{
  "name": "css-module-explainer",
  "displayName": "CSS Module Explainer",
  "version": "2.0.0",
  "private": true,
  "description": "Go to Definition, Hover, Autocomplete, Diagnostics, Quick Fixes, and Find References for classnames/bind cx() patterns with CSS Modules.",
  "categories": [
    "Linters",
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "autocomplete",
    "classnames",
    "classnames-bind",
    "css-modules",
    "cx",
    "hover",
    "intellisense",
    "lsp",
    "react",
    "scss"
  ],
  "homepage": "https://github.com/yongsk0066/css-module-explainer#readme",
  "bugs": {
    "url": "https://github.com/yongsk0066/css-module-explainer/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yongsk0066/css-module-explainer"
  },
  "qna": "marketplace",
  "publisher": "yongsk0066",
  "main": "./dist/client/extension.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && rolldown -c rolldown.config.ts",
    "watch": "rolldown -c rolldown.config.ts --watch",
    "changeset": "changeset",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:unit:watch": "vitest test/unit",
    "test:protocol": "vitest run test/protocol",
    "test:protocol:watch": "vitest test/protocol",
    "test:extension-host": "node test/extension-host/run-smoke.cjs",
    "test:bench": "vitest bench --run test/benchmark",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "test:coverage": "vitest run --coverage",
    "package": "pnpm build && vsce package --no-dependencies",
    "version-packages": "changeset version && ./scripts/release.sh",
    "release:verify": "./scripts/release.sh && pnpm check && pnpm test && pnpm build",
    "release:publish": "./scripts/publish-extension.sh"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.115.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.10",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "rolldown": "1.0.0-rc.15",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "contributes": {
    "configuration": {
      "title": "CSS Module Explainer",
      "properties": {
        "cssModuleExplainer.features.definition": {
          "type": "boolean",
          "default": true,
          "description": "Enable Go to Definition for cx() class names."
        },
        "cssModuleExplainer.features.hover": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover information for cx() class names."
        },
        "cssModuleExplainer.features.completion": {
          "type": "boolean",
          "default": true,
          "description": "Enable autocomplete inside cx() calls."
        },
        "cssModuleExplainer.features.references": {
          "type": "boolean",
          "default": true,
          "description": "Enable Find References for CSS class selectors."
        },
        "cssModuleExplainer.features.rename": {
          "type": "boolean",
          "default": true,
          "description": "Enable Rename Symbol for CSS class selectors across SCSS and TS/TSX files."
        },
        "cssModuleExplainer.diagnostics.severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "hint"
          ],
          "default": "warning",
          "description": "Severity level for unresolved class diagnostics."
        },
        "cssModuleExplainer.diagnostics.unusedSelector": {
          "type": "boolean",
          "default": true,
          "description": "Show hints for CSS class selectors that are declared but never referenced in any TS/TSX file."
        },
        "cssModuleExplainer.diagnostics.missingModule": {
          "type": "boolean",
          "default": true,
          "description": "Warn when 'import styles from ...' for a CSS Module cannot be resolved on disk."
        },
        "cssModuleExplainer.hover.maxCandidates": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum template/variable candidates shown in hover."
        },
        "cssModuleExplainer.scss.classnameTransform": {
          "type": "string",
          "enum": [
            "asIs",
            "camelCase",
            "camelCaseOnly",
            "dashes",
            "dashesOnly"
          ],
          "default": "asIs",
          "markdownDescription": "Mirror of css-loader's `modules.localsConvention`. Controls how CSS class selectors are exposed to JS/TS — e.g. `.btn-primary` is reachable as `styles['btn-primary']` (`asIs`), both that and `styles.btnPrimary` (`camelCase`), or only `styles.btnPrimary` (`camelCaseOnly`). Port your `css-loader` setting verbatim."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:css",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:less",
    "onLanguage:scss",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "extensionKind": [
    "workspace"
  ],
  "preview": false,
  "engines": {
    "node": ">=22",
    "vscode": "^1.115.0"
  },
  "packageManager": "pnpm@10.30.3"
}
