{
  "name": "css-module-explainer",
  "displayName": "CSS Module Explainer",
  "version": "3.8.0",
  "private": true,
  "description": "Go to Definition, Hover, Autocomplete, Diagnostics, Quick Fixes, and Find References for classnames/bind cx() patterns with CSS Modules.",
  "categories": [
    "Linters",
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "autocomplete",
    "classnames",
    "classnames-bind",
    "css-modules",
    "cx",
    "hover",
    "intellisense",
    "lsp",
    "react",
    "scss"
  ],
  "homepage": "https://github.com/yongsk0066/css-module-explainer#readme",
  "bugs": {
    "url": "https://github.com/yongsk0066/css-module-explainer/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yongsk0066/css-module-explainer"
  },
  "qna": "marketplace",
  "publisher": "yongsk0066",
  "main": "./dist/client/extension.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && rolldown -c rolldown.config.ts",
    "watch": "rolldown -c rolldown.config.ts --watch",
    "changeset": "changeset",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "check:eslint-plugin-smoke": "tsx ./scripts/check-eslint-plugin-smoke.ts",
    "check:stylelint-plugin-smoke": "node ./scripts/check-stylelint-plugin-smoke.mjs",
    "check:backend-typecheck-smoke": "tsx ./scripts/check-backend-typecheck-smoke.ts",
    "check:type-fact-backend-parity": "tsx ./scripts/check-type-fact-backend-parity.ts",
    "check:rust-workspace": "cargo fmt --manifest-path rust/Cargo.toml --all --check && cargo check --manifest-path rust/Cargo.toml && cargo clippy --manifest-path rust/Cargo.toml --all-targets --all-features -- -D warnings",
    "check:rust-type-fact-compare": "tsx ./scripts/check-rust-type-fact-compare.ts",
    "check:rust-query-plan-compare": "tsx ./scripts/check-rust-query-plan-compare.ts",
    "check:rust-expression-domain-compare": "tsx ./scripts/check-rust-expression-domain-compare.ts",
    "check:rust-expression-domain-fragments": "tsx ./scripts/check-rust-expression-domain-fragments.ts",
    "check:rust-expression-domain-candidates": "tsx ./scripts/check-rust-expression-domain-candidates.ts",
    "check:rust-expression-domain-canonical-candidate": "tsx ./scripts/check-rust-expression-domain-canonical-candidate.ts",
    "check:rust-expression-domain-evaluator-candidates": "tsx ./scripts/check-rust-expression-domain-evaluator-candidates.ts",
    "check:rust-expression-domain-canonical-producer": "tsx ./scripts/check-rust-expression-domain-canonical-producer.ts",
    "check:rust-expression-semantics-candidates": "tsx ./scripts/check-rust-expression-semantics-candidates.ts",
    "check:rust-expression-semantics-fragments": "tsx ./scripts/check-rust-expression-semantics-fragments.ts",
    "check:rust-expression-semantics-query-fragments": "tsx ./scripts/check-rust-expression-semantics-query-fragments.ts",
    "check:rust-expression-semantics-match-fragments": "tsx ./scripts/check-rust-expression-semantics-match-fragments.ts",
    "check:rust-expression-semantics-canonical-candidate": "tsx ./scripts/check-rust-expression-semantics-canonical-candidate.ts",
    "check:rust-expression-semantics-evaluator-candidates": "tsx ./scripts/check-rust-expression-semantics-evaluator-candidates.ts",
    "check:rust-expression-semantics-canonical-producer": "tsx ./scripts/check-rust-expression-semantics-canonical-producer.ts",
    "check:rust-source-side-canonical-candidate": "tsx ./scripts/check-rust-source-side-canonical-candidate.ts",
    "check:rust-source-side-evaluator-candidates": "tsx ./scripts/check-rust-source-side-evaluator-candidates.ts",
    "check:rust-source-side-canonical-producer": "tsx ./scripts/check-rust-source-side-canonical-producer.ts",
    "check:rust-source-resolution-match-fragments": "tsx ./scripts/check-rust-source-resolution-match-fragments.ts",
    "check:rust-source-resolution-candidates": "tsx ./scripts/check-rust-source-resolution-candidates.ts",
    "check:rust-source-resolution-evaluator-candidates": "tsx ./scripts/check-rust-source-resolution-evaluator-candidates.ts",
    "check:rust-source-resolution-fragments": "tsx ./scripts/check-rust-source-resolution-fragments.ts",
    "check:rust-source-resolution-query-fragments": "tsx ./scripts/check-rust-source-resolution-query-fragments.ts",
    "check:rust-source-resolution-canonical-candidate": "tsx ./scripts/check-rust-source-resolution-canonical-candidate.ts",
    "check:rust-source-resolution-canonical-producer": "tsx ./scripts/check-rust-source-resolution-canonical-producer.ts",
    "check:rust-selector-usage-plan-compare": "tsx ./scripts/check-rust-selector-usage-plan-compare.ts",
    "check:rust-selector-usage-fragments": "tsx ./scripts/check-rust-selector-usage-fragments.ts",
    "check:rust-selector-usage-query-fragments": "tsx ./scripts/check-rust-selector-usage-query-fragments.ts",
    "check:rust-source-resolution-plan-compare": "tsx ./scripts/check-rust-source-resolution-plan-compare.ts",
    "check:rust-shadow-smoke": "tsx ./scripts/check-rust-shadow-smoke.ts",
    "check:rust-shadow-compare": "tsx ./scripts/check-rust-shadow-compare.ts",
    "check:workspace": "tsx ./scripts/check-workspace.ts",
    "explain:expression": "tsx ./scripts/explain-expression.ts",
    "check:semantic-smoke": "tsx ./scripts/check-semantic-smoke.ts",
    "check:lsp-server-smoke": "tsx ./scripts/check-lsp-server-smoke.ts",
    "check:rust-gate-evidence": "tsx ./scripts/check-rust-gate-evidence.ts",
    "check:real-project-corpus": "tsx ./scripts/check-real-project-corpus.ts",
    "check:release-batch": "tsx ./scripts/check-release-batch.ts",
    "check:contract-parity-v1-smoke": "tsx ./scripts/check-contract-parity-v1-smoke.ts",
    "check:contract-parity-v1-golden": "tsx ./scripts/check-contract-parity-v1-golden.ts",
    "update:contract-parity-v1-golden": "tsx ./scripts/update-contract-parity-v1-golden.ts",
    "check:contract-parity-smoke": "pnpm check:contract-parity-v1-smoke",
    "check:contract-parity-golden": "pnpm check:contract-parity-v1-golden",
    "update:contract-parity-golden": "pnpm update:contract-parity-v1-golden",
    "check:contract-parity-v2-smoke": "tsx ./scripts/check-contract-parity-v2-smoke.ts",
    "check:contract-parity-v2-golden": "tsx ./scripts/check-contract-parity-v2-golden.ts",
    "update:contract-parity-v2-golden": "tsx ./scripts/update-contract-parity-v2-golden.ts",
    "test:unit": "vitest run test/unit",
    "test:unit:watch": "vitest test/unit",
    "test:protocol": "vitest run test/protocol",
    "test:protocol:watch": "vitest test/protocol",
    "test:extension-host": "node test/extension-host/run-smoke.cjs",
    "test:bench": "vitest bench --run test/benchmark",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck",
    "test:coverage": "vitest run --coverage",
    "package": "pnpm build && vsce package --no-dependencies",
    "version-packages": "changeset version && ./scripts/release.sh",
    "release:verify": "./scripts/release.sh && pnpm check && pnpm check:rust-workspace && pnpm check:rust-gate-evidence -- --variant typescript-current --repeat 1 --json && pnpm test && pnpm build",
    "release:publish": "./scripts/publish-extension.sh"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.8.0",
    "eslint": "^9.39.1",
    "eslint-plugin-css-module-explainer": "workspace:*",
    "fast-glob": "^3.3.3",
    "ovsx": "^0.10.11",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "rolldown": "1.0.0-rc.15",
    "stylelint": "^17.8.0",
    "stylelint-plugin-css-module-explainer": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "contributes": {
    "configuration": {
      "title": "CSS Module Explainer",
      "properties": {
        "cssModuleExplainer.features.definition": {
          "type": "boolean",
          "default": true,
          "description": "Enable Go to Definition for cx() class names."
        },
        "cssModuleExplainer.features.hover": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover information for cx() class names."
        },
        "cssModuleExplainer.features.completion": {
          "type": "boolean",
          "default": true,
          "description": "Enable autocomplete inside cx() calls."
        },
        "cssModuleExplainer.features.references": {
          "type": "boolean",
          "default": true,
          "description": "Enable Find References for CSS class selectors."
        },
        "cssModuleExplainer.features.rename": {
          "type": "boolean",
          "default": true,
          "description": "Enable Rename Symbol for CSS class selectors across SCSS and TS/TSX files."
        },
        "cssModuleExplainer.diagnostics.severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "hint"
          ],
          "default": "warning",
          "description": "Severity level for unresolved class diagnostics."
        },
        "cssModuleExplainer.diagnostics.unusedSelector": {
          "type": "boolean",
          "default": true,
          "description": "Show hints for CSS class selectors that are declared but never referenced in any TS/TSX file."
        },
        "cssModuleExplainer.diagnostics.missingModule": {
          "type": "boolean",
          "default": true,
          "description": "Warn when 'import styles from ...' for a CSS Module cannot be resolved on disk."
        },
        "cssModuleExplainer.hover.maxCandidates": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum template/variable candidates shown in hover."
        },
        "cssModuleExplainer.pathAlias": {
          "type": "object",
          "default": {},
          "scope": "resource",
          "markdownDescription": "Resource-scoped import alias map for CSS Module paths. Keys are non-relative import prefixes, values are workspace-relative or absolute target paths. This key takes precedence over the compatibility fallback from `cssModules.pathAlias`, which is deprecated and scheduled for removal in `4.0.0`."
        },
        "cssModuleExplainer.scss.classnameTransform": {
          "type": "string",
          "enum": [
            "asIs",
            "camelCase",
            "camelCaseOnly",
            "dashes",
            "dashesOnly"
          ],
          "default": "asIs",
          "scope": "resource",
          "markdownDescription": "Mirror of css-loader's `modules.localsConvention`. Controls how CSS class selectors are exposed to JS/TS — e.g. `.btn-primary` is reachable as `styles['btn-primary']` (`asIs`), both that and `styles.btnPrimary` (`camelCase`), or only `styles.btnPrimary` (`camelCaseOnly`). Port your `css-loader` setting verbatim."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:css",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:less",
    "onLanguage:scss",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "extensionKind": [
    "workspace"
  ],
  "preview": false,
  "engines": {
    "node": ">=22",
    "vscode": "^1.115.0"
  },
  "packageManager": "pnpm@10.30.3"
}
